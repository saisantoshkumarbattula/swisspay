# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in values
# cp .env.example .env
#
# All services run in Docker containers on EC2.
# Host names are Docker Compose service names (not localhost).
# NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (Compose service: postgres)
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis password (Compose service: redis)
REDIS_PASSWORD=swiftredis